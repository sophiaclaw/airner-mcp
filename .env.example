# Airner MCP Server — Environment Variables
# Copy this to .env and fill in values

# Port for HTTP API server
PORT=3000

# Google Sheets — choose one auth mode:
# Mode 1: Direct OAuth2 (for Railway / production)
#   Get these from: https://console.cloud.google.com/apis/credentials
#   Or export from gws: gws auth export
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Sheet ID (default: Airner sheet)
GOOGLE_SHEET_ID=1MnXcWeUeQ3H1WUA7nOf3fEEMHHU3cuiNrQPXj_nEXeM

# Mode 2: gws CLI (local Mac Mini / dev only)
# No env vars needed — gws CLI must be in PATH with valid credentials

# GitHub OAuth App credentials (optional — for agent registration flow)
# Create at: https://github.com/settings/applications/new
# Homepage URL: https://go.airtm.com/hire
# Callback URL: https://airner.railway.app/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Path to agents.json file
# On Railway: not needed (agents are in-memory or use a different store)
# Locally: defaults to workspace/airner-hire/agents.json
# AGENTS_FILE=/Users/clawbot/.openclaw/workspace/airner-hire/agents.json

# Force MCP stdio mode even if stdin is a TTY
# MCP_MODE=stdio
